---
const benefits = [
  { icon: '💵', title: 'Passive Income', body: "Your capital works. You don't have to." },
  { icon: '🛡️', title: 'Secured by Real Property', body: 'Every investment backed by land.' },
  { icon: '🚪', title: 'No Tenants. No Toilets.', body: 'Land investing without the landlord headaches.' },
  { icon: '⛰️', title: 'Recession Resilient', body: "Land holds value when markets don't." },
  { icon: '🧭', title: 'Simple Structure', body: "You'll understand exactly what you're getting." },
  { icon: '🤝', title: 'Direct Access', body: 'You work with David directly. No middlemen.' },
];
---

<section class="bg-surface border-y border-border-dark py-12 md:py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 md:gap-6">
      {benefits.map((b) => (
        <div class="reveal text-center px-3 py-4">
          <div class="text-3xl md:text-4xl mb-3" aria-hidden="true">{b.icon}</div>
          <h3 class="font-display text-base md:text-lg text-white leading-tight mb-2">{b.title}</h3>
          <p class="text-xs md:text-sm text-text-muted leading-snug">{b.body}</p>
        </div>
      ))}
    </div>
  </div>
</section>
