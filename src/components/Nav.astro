---
const currentPath = Astro.url.pathname;
const isHome = currentPath === '/';
---

<header class="bg-bg-dark/95 backdrop-blur border-b border-border-dark sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16 md:h-20">
      <a href="/" class="flex items-center flex-shrink-0" aria-label="alot.capital home">
        <img src="/images/logo-wide.png" alt="alot.capital" class="h-9 md:h-10 w-auto" />
      </a>

      <div class="hidden md:flex items-center gap-4">
        {isHome && (
          <a href="#lead-magnet" class="text-sm text-white/80 hover:text-white transition-colors font-medium">
            Free Guide
          </a>
        )}
        <a href="/request-invitation" class="btn-gold !px-5 !py-2.5 text-sm animate-gold-pulse">
          Request an Invitation
        </a>
      </div>

      <button id="menu-toggle" class="md:hidden text-white/90 p-2" aria-label="Toggle menu">
        <svg id="icon-open" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        <svg id="icon-close" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="md:hidden hidden border-t border-border-dark bg-bg-dark">
    <div class="px-4 py-4 space-y-3">
      {isHome && (
        <a href="#lead-magnet" class="block py-2 text-white/90 font-medium">Free Guide</a>
      )}
      <a href="/request-invitation" class="block btn-gold text-center">
        Request an Invitation
      </a>
    </div>
  </div>
</header>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const toggle = document.getElementById('menu-toggle');
    const menu = document.getElementById('mobile-menu');
    const iOpen = document.getElementById('icon-open');
    const iClose = document.getElementById('icon-close');
    if (toggle && menu) {
      toggle.addEventListener('click', () => {
        menu.classList.toggle('hidden');
        iOpen && iOpen.classList.toggle('hidden');
        iClose && iClose.classList.toggle('hidden');
      });
    }
  });
</script>
