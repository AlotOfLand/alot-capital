---
const year = new Date().getFullYear();
---

<footer class="bg-bg-dark border-t border-border-dark">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
    <div class="grid md:grid-cols-3 gap-10 md:gap-8 items-start">

      <!-- Brand -->
      <div>
        <a href="/" class="inline-block mb-4">
          <img src="/images/logo-wide.png" alt="alot.capital" class="h-16 w-auto" />
        </a>
        <p class="text-text-muted text-sm leading-relaxed max-w-xs">
          A Lot of Land LLC — Private land investments in Middle Tennessee.
        </p>
      </div>

      <!-- Contact -->
      <div>
        <h4 class="font-display text-white text-lg mb-3">Get in touch</h4>
        <ul class="space-y-2 text-sm">
          <li>
            <a href="mailto:David@alot.capital" class="text-white/85 hover:text-gold transition-colors">
              David@alot.capital
            </a>
          </li>
          <li>
            <a href="https://alot.land" target="_blank" rel="noopener" class="text-text-muted hover:text-white transition-colors">
              Our land deals: alot.land
            </a>
          </li>
        </ul>
      </div>

      <!-- CTAs + socials -->
      <div class="md:text-right">
        <a href="/request-invitation" class="btn-gold inline-flex text-sm">Request an Invitation</a>
        <div class="flex md:justify-end gap-3 mt-5">
